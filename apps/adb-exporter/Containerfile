ARG GO_TOOLSET_IMAGE=registry.access.redhat.com/ubi9/go-toolset:9.8-1784638038@sha256:981cd8d53cc230b928db75a697586f915da5d3ed6731eddb246ce8865e0b1400
ARG UBI_IMAGE=registry.access.redhat.com/ubi9/ubi:9.8-1784625744@sha256:b88557038cd6b46a7eddea604aad1313354185bb7fbbf499c0b423936e4944e1
ARG UBI_IMAGE_MICRO=registry.access.redhat.com/ubi9/ubi-micro:9.8-1782840931@sha256:35de56a9413112f1474e392ebc35e0cf6f0fb484c8e8877bbae59b513694b41f

FROM ${UBI_IMAGE_MICRO} AS target

# Build adb-exporter from source at a pinned tag
FROM ${GO_TOOLSET_IMAGE} AS build

# renovate: datasource=github-tags depName=david-igou/adb-exporter
ARG ADB_EXPORTER_VERSION="v0.1.0"

WORKDIR /opt/app-root/src
RUN git clone --depth 1 --branch "${ADB_EXPORTER_VERSION}" https://github.com/david-igou/adb-exporter.git src && \
    cd src && \
    CGO_ENABLED=0 go build -trimpath \
      -ldflags "-s -w -X main.version=${ADB_EXPORTER_VERSION} -X main.revision=$(git rev-parse --short HEAD)" \
      -o ../adb-exporter .

# Assemble the runtime rootfs: ubi-micro + the adb CLI the exporter execs.
# android-tools (adb) comes from EPEL 9 — it is not packaged in EPEL 10, which
# is why this image is UBI 9. Its libprotobuf dependency is in RHEL AppStream
# but not in UBI's repo subset, so protobuf alone comes from CentOS Stream 9
# AppStream (same el9 ABI).
FROM ${UBI_IMAGE} AS rootfs

ARG DNF_INSTALL_ROOT="/mnt/rootfs"
ARG DNF_OPTS="--setopt install_weak_deps=false --nodocs"

RUN mkdir -p ${DNF_INSTALL_ROOT}
COPY --from=target / ${DNF_INSTALL_ROOT}/

RUN dnf install -y --installroot ${DNF_INSTALL_ROOT} --releasever 9 ${DNF_OPTS} \
      https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm && \
    # repo configs are read from the installroot, but file:// gpgkey paths are
    # read from this build stage — mirror the EPEL key out of the installroot
    cp ${DNF_INSTALL_ROOT}/etc/pki/rpm-gpg/RPM-GPG-KEY-EPEL-9 /etc/pki/rpm-gpg/ && \
    dnf install -y --installroot ${DNF_INSTALL_ROOT} --releasever 9 ${DNF_OPTS} \
      --repofrompath cs9-appstream,https://mirror.stream.centos.org/9-stream/AppStream/$(arch)/os/ \
      --setopt=cs9-appstream.gpgcheck=1 \
      --setopt=cs9-appstream.gpgkey=https://www.centos.org/keys/RPM-GPG-KEY-CentOS-Official \
      android-tools && \
    dnf --installroot ${DNF_INSTALL_ROOT} clean all && \
    rm -rf ${DNF_INSTALL_ROOT}/var/cache/* ${DNF_INSTALL_ROOT}/var/log/dnf* ${DNF_INSTALL_ROOT}/var/log/yum.*

# Writable home for the adb client key (~/.android/adbkey): UID 1001, GID=0
# group-writable so OpenShift arbitrary-UID containers can write it too.
RUN mkdir -p ${DNF_INSTALL_ROOT}/home/adb-exporter && \
    chown 1001:0 ${DNF_INSTALL_ROOT}/home/adb-exporter && \
    chmod 0775 ${DNF_INSTALL_ROOT}/home/adb-exporter

FROM scratch

ARG DNF_INSTALL_ROOT="/mnt/rootfs"

COPY --from=rootfs ${DNF_INSTALL_ROOT}/ /
COPY --from=build /opt/app-root/src/adb-exporter /usr/local/bin/adb-exporter

ENV HOME=/home/adb-exporter
USER 1001
EXPOSE 9836
ENTRYPOINT ["/usr/local/bin/adb-exporter"]
