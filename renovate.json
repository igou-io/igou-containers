{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>igou-io/igou-devenv//renovate-base.json"
  ],
  "packageRules": [
    {
      "matchManagers": ["pip_requirements"],
      "groupName": "python dependencies"
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "container base images"
    },
    {
      "matchManagers": ["custom.regex"],
      "groupName": "cli tools"
    },
    {
      "description": "Track the OpenZFS 2.3 line — must match the TrueNAS 25.10 host kmod (zfs-exporter)",
      "matchDepNames": ["openzfs/zfs"],
      "allowedVersions": "<2.4.0"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "UBI base images carry security fixes as new digests/builds — ship them immediately, outside the weekly schedule and age gate",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["registry.access.redhat.com/**"],
      "groupName": "ubi base images",
      "schedule": ["at any time"],
      "minimumReleaseAge": null
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies"
    }
  ],
  "customManagers": [
    {
      "description": "Update pinned versions in Containerfiles via '# renovate:' comments",
      "customType": "regex",
      "managerFilePatterns": ["/Containerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?\\n(?:ARG )?\\w+_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "semver"
    }
  ]
}
